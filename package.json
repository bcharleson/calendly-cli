{
  "name": "calendly-cli",
  "version": "1.0.5",
  "description": "Agent-native CLI and MCP server for the Calendly API — 40 tools for scheduling automation",
  "type": "module",
  "bin": {
    "calendly": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "homepage": "https://github.com/bcharleson/calendly-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcharleson/calendly-cli.git"
  },
  "bugs": {
    "url": "https://github.com/bcharleson/calendly-cli/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "calendly",
    "cli",
    "mcp",
    "scheduling",
    "calendar",
    "agent"
  ],
  "license": "MIT"
}
